/*
 * Basic combinatorics
 * Bart Massey 1995..2001
 * Provides a nice namespaces demo also.
 */

namespace Combinatorics {

  public int function perm(n, r) {
    return n! // r!;
  }

  public int function choose(n, r) {
    return n! // (r! * (n - r)!);
  }

  public int function binom(n, k) {
    int sum, i;

    sum = 1;
    for (i = 1; i <= k; i++)
	  sum += choose(n, i);
    return sum;
  }

}
